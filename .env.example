# Database configuration
# PostgreSQL DSN format: postgresql://[user]:[password]@[host]:[port]/[database]
# Direct TimescaleDB port is typically 5432, PgBouncer transaction mode port is 6432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockbit_explorer

# Path to the captured session headers JSON file
STOCKBIT_HEADERS_PATH=data/session_headers.json

# Delay between sequential API requests in milliseconds to avoid HTTP 429
BACKLOAD_DELAY_MS=500
